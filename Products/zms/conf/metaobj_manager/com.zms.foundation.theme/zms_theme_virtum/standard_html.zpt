<!DOCTYPE html>
<html lang="en" tal:define="
		Std modules/Products.PythonScripts/standard;
		standard modules/Products.zms/standard;
		newline_to_br nocall:Std/newline_to_br;
		zmscontext options/zmscontext;
		dummy0 python:zmscontext.f_standard_html_request();
		zmsroot python:zmscontext.breadcrumbs_obj_path()[0];
		zmsclient python:zmscontext.content;
		lang request/lang;
		this here;
		attr_dc_type python:zmscontext.attr('attr_dc_type').lower();
		search_conf python:zmscontext.getConfProperty('ZMS.permalink.search', default='');
		imprint_conf python:zmscontext.getConfProperty('ZMS.permalink.imprint', default='');
		privacy_conf python:zmscontext.getConfProperty('ZMS.permalink.privacy', default='');
		login_conf python:zmscontext.getConfProperty('ZMS.permalink.login', default='');
		contact_conf python:zmscontext.getConfProperty('ZMS.permalink.contact', default='');
		search_node python:search_conf and zmscontext.getLinkObj(search_conf, request) or None;
		imprint_node python:imprint_conf and zmscontext.getLinkObj(imprint_conf, request) or None;
		privacy_node python:privacy_conf and zmscontext.getLinkObj(privacy_conf, request) or None;
		login_node python:login_conf and zmscontext.getLinkObj(login_conf, request) or None;
		contact_node python:contact_conf and zmscontext.getLinkObj(contact_conf, request) or None;
		dummy python:request.set('ZMS_THIS',here);
		common python:container.common.absolute_url();
		tmpl_url python:container.absolute_url();
		site_nodes python:[node for node in zmsclient.filteredChildNodes(request, zmsroot.PAGES) if node.attr('attr_dc_type') != 'Resource'];
		teasers python:zmscontext.getTeaserElements();
		is_root python:zmscontext.getId() == zmsroot.getId();
		hero_image python:zmscontext.attr('titleimage') or zmsclient.attr('titleimage');
		hero_image_url python:hero_image and hero_image.getHref(request) or '';
		hero_style python:hero_image_url and &quot;background-image: linear-gradient(145deg, rgba(6, 53, 89, 0.92), rgba(6, 53, 89, 0.78)), url('%s')&quot;%hero_image_url or default;
		first_page python:len(site_nodes) and site_nodes[0] or None;
		">
<head>
	<meta http-equiv="content-type" content="text/html;charset=utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="generator" content="ZMS6" />
	<title tal:content="structure python:zmscontext.getTitlealt(request)">ZMS</title>
	<meta tal:attributes="content python:zmscontext.attr('attr_dc_description')" name="description" content="" />
	<meta tal:attributes="content python:zmscontext.attr('attr_dc_subject')" name="keywords" content="" />
	<meta name="author" tal:attributes="content python:zmscontext.attr('attr_dc_creator')" />

	<link rel="stylesheet" href="theme.css" tal:attributes="href python:'%s/common/css/style.css'%(tmpl_url)" />
	<link rel="stylesheet" href="custom.css" tal:attributes="href python:'%s/added/web.css'%(common)" />

	<script src="/++resource++zms_/zmi.js"></script>
	<link rel="shortcut icon" href="favicon.ico" type="image/ico" tal:attributes="href python:'%s/common/img/favicon.ico'%(tmpl_url)" />
</head>
<body tal:attributes="
	data-path python:zmscontext.getRootElement().getRefObjPath(here);
	data-root python:zmscontext.getRootElement().getHome().id;
	data-client python:zmsclient.getHome().id;
	data-level python:zmscontext.getLevel();
	id python:'zmsid_%s'%(zmscontext.id);
	class python:'zms web virtum %s %s %s'%(zmscontext.meta_id, attr_dc_type, is_root and 'is-root' or 'is-detail')">

	<header class="virtum-header" tal:attributes="style hero_style | nothing">
		<div class="virtum-header-bar">
			<a class="site-brand" href="#" tal:attributes="href python:zmsclient.getHref2IndexHtml(request)">
				<img class="site-brand-logo" src="common/img/zmslogo.svg" alt="Logo"
					tal:attributes="src python:'%s/common/img/zmslogo.svg'%(tmpl_url); title python:zmsclient.getTitlealt(request)" />
			</a>
			<p class="site-tagline">
				We're open for collabs.
				<a href="#" tal:condition="python:contact_node is not None" tal:attributes="href python:contact_node.getHref2IndexHtml(request)">Get in touch.</a>
			</p>
			<div class="site-nav-wrap">
				<button type="button" class="menu-toggle" aria-expanded="false" aria-controls="virtumNav">Menu</button>
				<nav id="virtumNav" class="site-nav" aria-label="Main navigation">
					<ul>
						<li tal:repeat="child_node site_nodes" tal:attributes="class python:child_node in zmscontext.breadcrumbs_obj_path() and 'active' or ''">
							<a href="#"
								tal:attributes="href python:child_node.getHref2IndexHtml(request); title python:child_node.attr('title')"
								tal:content="python:child_node.getTitlealt(request)">Section</a>
						</li>
						<li tal:condition="python:search_node is not None"><a href="#" tal:attributes="href python:search_node.getHref2IndexHtml(request)" tal:content="python:zmscontext.getLangStr('SEARCH')">Search</a></li>
					</ul>
				</nav>
			</div>
		</div>
		<div class="virtum-hero">
			<p class="hero-kicker">Vitrum inspired ZMS templateset</p>
			<h1 tal:content="structure python:zmscontext.getTitlealt(request)">GlassBenders Guild</h1>
			<p tal:content="structure python:newline_to_br(zmscontext.attr('attr_dc_description') or zmsclient.attr('attr_dc_description') or '')">
				Wide page compositions with generous typography and imagery, adapted from Automattic's Vitrum visual direction.
			</p>
			<div class="hero-actions" tal:condition="python:is_root">
				<a class="btn-primary" href="#grid" tal:condition="python:first_page is not None">Explore sections</a>
				<a class="btn-outline" href="#" tal:condition="python:first_page is not None" tal:attributes="href python:first_page and first_page.getHref2IndexHtml(request) or '#'">Open first page</a>
			</div>
		</div>
	</header>

	<main class="virtum-main" tal:condition="is_root">
		<section class="virtum-lead">
			<div class="virtum-columns">
				<div>
					<h2>Portfolio-like storytelling for ZMS sites</h2>
				</div>
				<div>
					<p>
						This theme keeps the Vitrum approach of clear blocks, broad spacing and concise text while using native ZMS navigation, body rendering and teaser elements.
					</p>
				</div>
			</div>
		</section>

		<section id="grid" class="virtum-grid" tal:condition="python:len(site_nodes) &gt; 0">
			<article class="virtum-card" tal:repeat="child_node site_nodes">
				<tal:block tal:define="card_image python:child_node.attr('titleimage'); card_image_url python:card_image and card_image.getHref(request) or ''; card_style python:card_image_url and 'background-image:url(%s)'%card_image_url or default">
					<a href="#" tal:attributes="href python:child_node.getHref2IndexHtml(request)">
						<div class="virtum-card-media" tal:attributes="style card_style | nothing"></div>
						<h3 tal:content="python:child_node.getTitlealt(request)">Section</h3>
						<p tal:content="python:child_node.attr('attr_dc_description') or zmscontext.getLangStr('BTN_READMORE')">Description</p>
						<span class="card-link">Open page</span>
					</a>
				</tal:block>
			</article>
		</section>

		<section class="virtum-content-home">
			<div class="virtum-flow" tal:content="structure python:zmscontext.getBodyContent(request)">CONTENT BODY</div>
		</section>
	</main>

	<main class="virtum-main detail" tal:condition="not:is_root">
		<nav aria-label="breadcrumb" class="virtum-breadcrumb">
			<ol>
				<li tal:repeat="node python:zmscontext.breadcrumbs_obj_path()"
					tal:attributes="class python:node == zmscontext and 'active' or ''">
					<a href="#" tal:attributes="href python:node.getHref2IndexHtml(request, deep=1)" tal:content="python:node.getTitlealt(request)">the titlealt</a>
				</li>
			</ol>
		</nav>

		<section class="virtum-detail-head">
			<h2 tal:content="structure python:zmscontext.attr('title')">TITLE</h2>
			<p tal:content="structure python:newline_to_br(zmscontext.attr('attr_dc_description') or '')">DESCRIPTION</p>
		</section>

		<section class="virtum-content-sheet">
			<div class="virtum-flow" tal:content="structure python:zmscontext.getBodyContent(request)">CONTENT BODY</div>
			<div class="teaser-strip" tal:condition="python:len(teasers) &gt; 0">
				<div tal:repeat="teaser teasers" tal:replace="structure python:teaser.renderShort(request)">TEASER</div>
			</div>
			<nav class="toc-shell" metal:use-macro="container/pageelements/macros/toc">TABLE OF CONTENT</nav>
		</section>
	</main>
	<footer class="virtum-footer" metal:use-macro="container/pageelements/macros/footer">FOOTER</footer>

	<script type="text/javascript" charset="UTF-8" src="/++resource++zms_/i18n/ger.js" tal:attributes="src python:'/++resource++zms_/i18n/%s.js'%request.get('lang','eng')"></script>
	<script type="text/javascript" charset="UTF-8" src="/++resource++zmi/jquery-3.5.1.min.js"></script>
	<script type="text/javascript" charset="UTF-8" src="/++resource++zms_/zmi.core.js"></script>
	<script type="text/javascript" charset="UTF-8" src="/++resource++zms_/ZMS/zmi_body_content_search.js"></script>
	<script src="theme.js" tal:attributes="src python:'%s/added/web.js'%(common)"></script>

	<tal:block tal:define="
		standard modules/Products.zms/standard;
		cache_expire python:standard.set_response_headers_cache(this, request, cache_max_age=6*3600, cache_s_maxage=-1)">
	</tal:block>
</body>
</html>
