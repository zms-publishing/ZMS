<!DOCTYPE html>
<html lang="en">
<head>
<title>Add ZMS LLM Connector</title>
</head>
<body>
<form method="post" action="manage_addZMSLLMConnector">
  <h2>Add ZMS LLM Connector</h2>
  <table>
    <tr>
      <td><label for="id">Id</label></td>
      <td><input type="text" name="id" id="id" value="llm_connector" /></td>
    </tr>
    <tr>
      <td colspan="2">
        <input type="submit" value="Add" />
      </td>
    </tr>
  </table>
</form>
</body>
</html>
