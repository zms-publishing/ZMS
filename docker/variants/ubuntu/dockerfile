FROM ubuntu:26.04

# Get environment variables from docker-compose.yml:
# So, image file must be created with docker-compose build
# ############################
ARG INSTANCE_DIR=/home/zope
ARG VENV_DIR=/home/zope/venv
ARG IS_DEBUG=false
ARG UID=1000
ARG GID=1000
# ############################

# Create zope user/group early (before package/install scripts may consume UID 1000)
RUN set -eux; \
    if ! getent group "${GID}" >/dev/null; then \
        groupadd -g "${GID}" zope; \
    fi; \
    if id -u zope >/dev/null 2>&1; then \
        usermod -u "${UID}" -g "${GID}" zope; \
    elif getent passwd "${UID}" >/dev/null; then \
        OLD_USER="$(getent passwd "${UID}" | cut -d: -f1)"; \
        usermod -l zope -d /home/zope -m "${OLD_USER}"; \
        usermod -g "${GID}" zope; \
    else \
        useradd -m -u "${UID}" -g "${GID}" -s /bin/bash zope; \
    fi

# Keep running as root for OS/package installation
USER root

# Non-interactive installs and default timezone to avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive TZ=Europe/Berlin

# Preconfigure timezone non-interactively
RUN apt-get update && \
	echo "tzdata tzdata/Areas select Europe" | debconf-set-selections && \
	echo "tzdata tzdata/Zones/Europe select Berlin" | debconf-set-selections && \
	apt-get install -y --no-install-recommends tzdata && \
	ln -fs /usr/share/zoneinfo/$TZ /etc/localtime && \
	dpkg-reconfigure -f noninteractive tzdata && \
	rm -rf /var/lib/apt/lists/*

# Install OS Requirements
RUN set -eux; \
    echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        apt-transport-https \
        build-essential \
        ca-certificates \
        curl \
        default-libmysqlclient-dev \
        docbook-xml \
        docbook-xsl \
        fop \
        gcc \
        gettext-base \
        git \
        g++ \
        gnupg \
        iproute2 \
        iputils-ping \
        libldap2-dev \
        libfop-java \
        libsasl2-dev \
        locales \
        locales-all \
        lsof \
        make \
        memcached \
        nano \
        netcat-openbsd \
        pkg-config \
        python3 \
        python3-dev \
        python3-venv \
        slapd \
        ttf-mscorefonts-installer \
        xalan \
        xsltproc; \
    update-ca-certificates; \
    rm -rf /var/lib/apt/lists/*

# Add Microsoft Package Servers for VSCode
RUN curl -sSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft.gpg
RUN echo "deb [arch=amd64 signed-by=/usr/share/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/vscode stable main" > /etc/apt/sources.list.d/vscode.list
RUN apt-get update
# Install VSCode Server as User root
RUN curl -fsSL https://code-server.dev/install.sh | sh

# Switch to User zope for all further steps, 
# including installing Python packages and running the instance
USER zope
WORKDIR /home/zope/

ENV ZOPE_VERSION=6.0
ENV ZMS_BRANCH=main
# ENV ZMS_BRANCH=main
ENV VIRTUAL_ENV=/home/zope/venv
ENV SHELL=/bin/bash
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8

# Install ZMS and Zope in a Virtual Environment
RUN python3 -m venv $VENV_DIR
RUN pip install -U pip wheel setuptools
RUN pip install Zope[wsgi]==$ZOPE_VERSION -c https://zopefoundation.github.io/Zope/releases/$ZOPE_VERSION/constraints.txt
RUN pip install -r https://raw.githubusercontent.com/zms-publishing/ZMS/main/requirements-full.txt
RUN pip install --config-settings editable_mode=compat --no-deps -e git+https://github.com/zms-publishing/ZMS.git@$ZMS_BRANCH#egg=ZMS
RUN pip install ZEO
RUN pip install itsdangerous
# RUN pip install debugpy

# Create Zope Instance
RUN mkwsgiinstance -d . -u admin:admin

# Mount Zope Instance Data
COPY ./etc etc
COPY ./var var
COPY ./Extensions Extensions
COPY ./import import

# Expose Ports:
# 8888 = VSCode-Server (Zope instance runs by VSCode launch)
# 8080 = Zope-Server (1 instance, for more instances, use docker-compose to map additional ports)
EXPOSE 8888
EXPOSE 8080

# Install VSCode Extension for local User zope
# RUN code-server --install-extension ms-python.python --user-data-dir /home/zope/.local/share/code-server

# Start Zope Instance / VSCode-Server via docker-compose